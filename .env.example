# LobCut environment template.
# Copy this file to .env and fill only the values you need.
# Keep real .env files private.

# Auth mode:
# - local: easiest for local demos and hackathon judging
# - google: enables Google OAuth login and requires the Google/JWT values below
LOBCUT_AUTH_MODE=

# Google OAuth (only required when LOBCUT_AUTH_MODE=google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=

# AI APIs
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
OPENAI_API_KEY=

# Telegram (optional - for notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_ALLOWED_USER_ID is no longer used - all users are allowed

# Docker watch path mappings (optional)
# Example when dashboard stores D:\Z-work\Input and Docker mounts it at /watch/user-input:
# WATCH_HOST_INPUT=D:/Z-work/Input
# WATCH_PATH_MAPPINGS=D:\LobCut\input=/app/input;D:\Z-work\Input=/watch/user-input
WATCH_HOST_INPUT=
WATCH_PATH_MAPPINGS=

# OpenClaw
OPENCLAW_GATEWAY_TOKEN=
