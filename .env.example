# LLM and media processing
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram gateway
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id_here

# Optional: WSL2-visible inbox folder to mount read-only into the stack
# Example: /mnt/c/Users/YourName/Videos/mediascribe-inbox
WATCH_INBOX=./data/inbox
