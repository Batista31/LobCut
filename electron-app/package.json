{
  "name": "lobcut",
  "version": "1.0.0",
  "description": "LobCut desktop wrapper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:dashboard": "cd ../dashboard && npm install && npm run build",
    "build:win": "npm run build:dashboard && electron-builder --win nsis",
    "pack:win": "npm run build:dashboard && electron-builder --win --dir"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.lobcut.desktop",
    "productName": "LobCut",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!out/**",
      "!npm-cache/**"
    ],
    "extraResources": [
      {
        "from": "../dashboard/dist",
        "to": "dashboard/dist"
      },
      {
        "from": "../docker-compose.yml",
        "to": "docker-compose.yml"
      },
      {
        "from": "../LobCut mark.jpeg",
        "to": "LobCut mark.jpeg"
      },
      {
        "from": "../LobCut mark.png",
        "to": "LobCut mark.png"
      },
      {
        "from": "../LobCut telegram.png",
        "to": "LobCut telegram.png"
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  }
}
